void countingSort(vector<int>&arr) {
    int maxele=*max_element(arr.begin(),arr.end());
vector<int>freq(maxele+1,0);
for(int j=0;j<arr.size();j++){
    freq[arr[j]]++; 
}
int k=0;
  for(int j=0;j<freq.size();j++){
     if(freq[j]!=0){

         while(freq[j]!=0){
        arr[k++]=j;
        freq[j]--; 
         }
     }
 }

}
