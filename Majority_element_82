#include <cmath>
#include <cstdio>
#include <vector>
#include <iostream>
#include <algorithm>
using namespace std;


int main() {
   
 /* Enter your code here. Read input from STDIN. Print output to STDOUT */   
int n;   cin>>n;
vector<int>vec(n,0);
   for(int i=0;i<n;i++){
    cin>>vec[i];
   }
   int num=0;
   int count=0;
   for(int j=0;j<n;j++){
    if(count==0){
        num=vec[j];
        count=1;
    }
    else if(num==vec[j]){
        count++;
    }
    else if(num!=vec[j]){
        count--;
    } 
   }
   count=0;
   for(int j=0;j<n;j++){
    if(num==vec[j]){
        count++;
    }
    if(count>(n/2)){
        cout<<num;
        return 0;
    }
   }
   cout<<-1;
   
   
   
    return 0;
}
