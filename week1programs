INTERCHANGING OF NUMBERS
#include <cmath>
#include <cstdio>
#include <vector>
#include <iostream>
#include <algorithm>
using namespace std;


int main() {
    /* Enter your code here. Read input from STDIN. Print output to STDOUT */ 
    int n;
    cin>>n;
    int vec[n]={0};
    for(int i=0;i<n;i++){
        cin>>vec[i];
    }
    int maxi=0;
    int mini=0;
    
    for(int i=1;i<n;i++){
        if(vec[i]>vec[maxi] ){
            maxi=i;
        }
        else if(vec[i]<vec[mini]){
            mini=i;
        }
    }
    swap(vec[maxi],vec[mini]);
    
    for(int i=0;i<n;i++){
        cout<<vec[i]<<" ";
    }
      
    return 0;
}

